# 生产环境默认值 — 部署到 Vercel 时在此填写你的 QMT 服务器地址
# 警告: VITE_ 前缀的变量会打包进 JS，不要在公开仓库提交真实地址和 token！

# 后端模式: "flask" | "xtquant" | "auto"
VITE_DEFAULT_BACKEND=xtquant

# xtquant_manager 网关地址（多账号统一入口，推荐）
VITE_DEFAULT_XTQUANT_URL=

# Flask 直连模式时各账号的地址（若使用 xtquant 网关则留空）
VITE_DEFAULT_FLASK_URL=

# API Token（与 xtquant_manager 的 SecurityConfig.api_token 或 Flask 的 QMT_API_TOKEN 一致）
VITE_DEFAULT_TOKEN=

VITE_APP_TITLE=miniQMT 2.0
