# miniQMT 环境变量配置文件
# ==============================================================================
# 使用方式：
#   1. 复制此文件为 .env（项目根目录）
#   2. 填入实际值
#   3. miniQMT 启动时自动加载（config.py 的 _load_dotenv_fallback）
#
# 优先级：Windows 用户级/系统环境变量 > .env fallback
#   即 setx 设置的变量始终生效，.env 仅补充尚未在环境变量中设置的键。
#   Windows CMD 示例：
#     setx ENABLE_QMT_RPC_FALLBACK true
#   PowerShell 示例：
#     [System.Environment]::SetEnvironmentVariable("ENABLE_QMT_RPC_FALLBACK","true","User")
# ==============================================================================

# ==============================================================================
# QMT 客户端路径配置
# ==============================================================================
# QMT 客户端安装路径（userdata_mini 目录），优先级高于 account_config.json
# 示例：C:/光大证券金阳光QMT实盘/userdata_mini
# QMT_PATH=C:/your-broker-qmt/userdata_mini

# ==============================================================================
# Web API 访问控制
# ==============================================================================
# Web API Token，用于保护敏感接口（买入/卖出/配置修改等）
#   - 留空或不设置：跳过 Token 验证（仅限纯内网部署，前端登录页免登录直入）
#   - 设置后：所有 POST/PUT/DELETE 请求需在请求头携带 X-API-Token: <token>
#     前端登录页要求输入此 token 才能进入
#
# 建议使用强随机字符串：
#   PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }))
#   Linux:      openssl rand -hex 32
QMT_API_TOKEN=your-secret-token-here

# ==============================================================================
# Tushare Pro 数据源（标准模式的历史K线和股票名称查询）
# ==============================================================================
# Tushare Pro Token（注册获取: https://tushare.pro）
#   设置后，标准模式下历史K线查询优先走 Tushare（失败时降级到 Mootdx）
#   Token 过期或积分不足不影响主系统运行（自动降级）
TUSHARE_TOKEN=your_tushare_token_here

# Tushare 数据源总开关（true=启用标准模式优先走 Tushare, false=禁用）
#   默认关闭。miniqmt.bat 菜单 [n] 可直接切换，无需手动编辑
ENABLE_TUSHARE_DATA_SOURCE=false

# ==============================================================================
# 大QMT 文件 IPC 交易通道（降级方案之一）
# ==============================================================================
# 适用场景：券商收紧 miniQMT xttrader 权限 / xttrader 失效时
# 原理：miniQMT 把订单写为 JSON 文件 → 大QMT内置 Python 脚本读取并执行
# 适用性：中低频策略（下单延迟 1-2 秒）；不适用高频/打板/tick抢单
#
# 详见 qmt-trader/部署手册.md
# miniqmt.bat 菜单 [o] 可直接配置

# 总开关（true=启用文件IPC通道，false=使用 xttrader 直连）。默认关闭
# ⚠️ 与 ENABLE_XTQUANT_MANAGER / ENABLE_QMT_RPC_FALLBACK 三者互斥，只能开一个
ENABLE_QMT_IPC_FALLBACK=false

# IPC 文件目录（策略端与大QMT端必须指向同一路径，多账号自动子目录隔离）
QMT_IPC_ROOT=C:\QuantIPC

# ==============================================================================
# 大QMT RPC 交易通道（降级方案之二，基于 Redis / ZMQ）
# ==============================================================================
# 适用场景：券商收紧 miniQMT xttrader 权限时
# 原理：miniQMT ↔ Redis/Memurai ↔ 大QMT策略进程 RPC 通信执行交易
# 优势：毫秒级延迟（Redis ~12ms, ZMQ ~0.2ms），可跨机部署，支持实时推送
# 安全性：默认只读（allow_order=false），需两端同时显式开启才可下单
#
# 详见 qmt-trader/大QMT-RPC方案.md 和 docs/site/miniqmt/qmt-rpc-redis-setup.md

# 总开关（true=启用RPC通道，false=使用 xttrader 直连）。默认关闭
# ⚠️ 与 ENABLE_XTQUANT_MANAGER / ENABLE_QMT_IPC_FALLBACK 三者互斥，只能开一个
ENABLE_QMT_RPC_FALLBACK=false

# 传输方式：redis（默认，生产推荐）/ zmq（同机低延迟，需 pyzmq）/ mysql（兼容兜底）
QMT_RPC_TRANSPORT=redis

# Redis 连接配置（使用 Memurai 或 Redis 服务，两端必须一致）
QMT_RPC_REDIS_HOST=127.0.0.1
QMT_RPC_REDIS_PORT=6379
QMT_RPC_REDIS_DB=5
QMT_RPC_REDIS_PASSWORD=your-redis-password-here

# RPC 请求超时（秒）
# QMT_RPC_TIMEOUT_SECONDS=6.0

# 下单后等待成交/委托回执的最大秒数
# QMT_RPC_ORDER_TIMEOUT=30

# 成交/委托回报轮询兜底间隔（秒），推送通道之外的补偿轮询
# QMT_RPC_DEAL_POLL_INTERVAL=1.0

# 下单二次确认开关（false=即使ENABLE_QMT_RPC_FALLBACK=true也拒绝下单，只读安全）
# 联调初期保持 false，确认只读链路无误后再改为 true
# ⚠️ 大QMT端 bigqmt_signal_trader_local_config.py 里的 rpc_allow_order_methods 也必须同步改为 True
QMT_RPC_ALLOW_ORDER=false

# ==============================================================================
# 数据源（开发/调试）
# ==============================================================================
# Baostock API Key（新版 baostock >= 00.9.x 需要登录激活）
# 注册获取: http://baostock.com
# BAOSTOCK_API_KEY=your_baostock_api_key_here
